{
  "name": "clippy-ai",
  "version": "2.1.0",
  "description": "Automated viral clip pipeline: YouTube → AI analysis → clip → post",
  "type": "module",
  "bin": {
    "clipbot": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "prompts/",
    "clipbot.config.json",
    "ui-standalone/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:package": "node scripts/build-package.mjs",
    "prepublishOnly": "npm run build:package",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "youtube",
    "clips",
    "viral",
    "tiktok",
    "shorts",
    "reels",
    "automation"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@remotion/captions": "^4.0.428",
    "@remotion/cli": "^4.0.428",
    "@remotion/renderer": "^4.0.428",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "inquirer": "^13.3.0",
    "ora": "^9.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.428",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/ffprobe-static": "^2.0.3",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
